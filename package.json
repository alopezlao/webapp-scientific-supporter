{
  "name": "research-hub",
  "version": "0.1.0",
  "description": "Herramienta para investigadores cientificos - App de escritorio",
  "main": "electron/main.cjs",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "workspaces": [
    "apps/desktop",
    "packages/ui-components",
    "packages/api-client",
    "packages/utils"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/desktop",
    "build:client": "npm run build -w apps/desktop",
    "desktop:dev": "concurrently \"npm run dev -w apps/desktop\" \"wait-on http://localhost:3000 && electron electron/main.cjs\"",
    "desktop:build": "npm run build:client && electron-builder",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --workspace",
    "precommit": "npm run lint && npm run format:check",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^8.2.0",
    "electron": "^26.0.0",
    "electron-builder": "^24.3.0",
    "wait-on": "^7.0.1",
    "eslint": "^10.0.3",
    "eslint-config-next": "^16.1.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
